# lucifer-research environment variables
# Copy this file to .env and fill in the values you have.
# All keys are optional — the pipeline works without them (rate-limited/degraded).

# YouTube Data API v3 key
# Without: oEmbed only (no view/like counts)
# Get one: https://console.developers.google.com
YOUTUBE_API_KEY=

# GitHub Personal Access Token (classic or fine-grained, public_repo scope)
# Without: 60 requests/hour unauthenticated
# Get one: https://github.com/settings/tokens
GITHUB_TOKEN=

# Jina Reader API key
# Without: anonymous tier (rate-limited)
# Get one: https://jina.ai/reader
JINA_API_KEY=

# Qiita API token
# Without: 60 requests/hour unauthenticated
# Get one: https://qiita.com/settings/tokens/new
QIITA_TOKEN=
